#!/bin/sh /etc/rc.common
# OpenWrt init.d script for 5map capture agent
# Install: cp to /etc/init.d/5map-agent && chmod +x && /etc/init.d/5map-agent enable

START=99
STOP=10
USE_PROCD=1

PROG="/usr/bin/python3"
AGENT="/opt/5map/pineapple/capture_agent.py"
CONFIG="/opt/5map/pineapple/config.yaml"
PIDFILE="/var/run/5map-agent.pid"

start_service() {
    # Setup monitor mode first
    /opt/5map/pineapple/setup_monitor.sh wlan0 wlan1 setup

    procd_open_instance
    procd_set_param command "$PROG" "$AGENT" --config "$CONFIG"
    procd_set_param pidfile "$PIDFILE"
    procd_set_param respawn 3600 5 10
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param nice 10
    procd_close_instance
}

stop_service() {
    # Restore radios to managed mode
    /opt/5map/pineapple/setup_monitor.sh wlan0 wlan1 restore
}

service_triggers() {
    procd_add_reload_trigger "5map"
}
